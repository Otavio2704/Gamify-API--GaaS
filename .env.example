# Copie este arquivo para .env e preencha com os dados do seu banco externo
# cp .env.example .env

# Banco externo (obrigatório)
DB_URL=jdbc:postgresql://SEU_HOST:5432/SEU_BANCO
DB_USERNAME=SEU_USUARIO
DB_PASSWORD=SUA_SENHA

# JWT em produção
JWT_SECRET=troque-por-um-secret-forte-com-pelo-menos-256bits
JWT_EXPIRATION_MS=86400000
